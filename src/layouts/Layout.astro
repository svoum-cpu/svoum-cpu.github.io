---
const { title } = Astro.props;
---
<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <title>{title} | Sofia Voumvourakis</title>
    <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,600;1,400&display=swap" rel="stylesheet">
    <style is:global>
      :root {
        --margin-color: #f0f4f4; /* Muted teal-grey for margins */
        --paper-white: #ffffff;
        --deep-teal: #28524f; /* For resume headers */
        --bright-teal: #3d7a76; /* For accents/name */
        --charcoal: #333333;
        --border-color: #d1d9d9;
      }
      
      body {
        margin: 0;
        background-color: var(--margin-color); /* The colored margins */
        font-family: "Times New Roman", Times, serif;
        color: var(--charcoal);
        display: flex;
        flex-direction: column;
        min-height: 100vh;
      }

      /* Main container creates the 'framed' look */
      .main-frame {
        background-color: var(--paper-white);
        max-width: 1200px;
        margin: 0 auto;
        width: 100%;
        flex-grow: 1;
        box-shadow: 0 0 50px rgba(0,0,0,0.05);
      }

      nav {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 2rem 5%;
        background-color: #ffffff;
        border-bottom: 2px solid var(--margin-color); /* Clear division */
      }

      .logo {
        font-family: 'Cormorant Garamond', serif;
        font-size: 2rem;
        text-decoration: none;
        color: var(--charcoal);
        font-weight: 300;
      }

      .nav-links {
        display: flex;
        gap: 2.5rem;
      }

      .nav-links a {
        text-decoration: none;
        color: var(--charcoal);
        font-family: 'Cormorant Garamond', serif;
        font-size: 1.2rem;
        /* No All-Caps */
        text-transform: none; 
        transition: color 0.3s ease;
      }

      .nav-links a:hover {
        color: var(--bright-teal);
      }

      h1, h2, h3 {
        font-family: 'Cormorant Garamond', serif;
        font-weight: 400;
      }
    </style>
  </head>
  <body>
    <div class="main-frame">
      <nav>
        <a href="/" class="logo">SV</a>
        <div class="nav-links">
          <a href="/">Home</a>
          <a href="/resume">Resume</a>
          <a href="/art">Art</a>
          <a href="/prose">Prose</a>
          <a href="/contact">Contact</a>
        </div>
      </nav>
      <slot />
    </div>
  </body>
</html>