---
const { title } = Astro.props;
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <title>{title} | Sofia Voumvourakis</title>
    <link href="https://fonts.googleapis.com/css2?family=Pinyon+Script&family=Cormorant+Garamond:ital,wght@0,300;0,600;1,400&display=swap" rel="stylesheet">
    <style is:global>
      :root {
        --tan-base: #FDF6EC;
        --tan-sidebar: #F5EBE0;
        --charcoal: #333333;
        --teal-accent: #4A7C77;
        --soft-teal: #D1DEDC;
      }
      
      body {
        margin: 0;
        background-color: var(--tan-base);
        color: var(--charcoal);
        font-family: "Times New Roman", Times, serif;
        line-height: 1.6;
      }

      .creative-header {
        font-family: 'Pinyon Script', cursive;
        font-weight: normal;
      }

      .elegant-title {
        font-family: 'Cormorant Garamond', serif;
        text-transform: uppercase;
        letter-spacing: 2px;
      }

      nav {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 2rem 10%;
      }

      .logo {
        font-family: 'Cormorant Garamond', serif;
        font-size: 2.2rem;
        text-decoration: none;
        color: var(--charcoal);
        font-weight: 300;
      }

      .nav-links {
        display: flex;
        gap: 2.5rem;
      }

      .nav-links a {
        text-decoration: none;
        color: var(--charcoal);
        font-family: 'Cormorant Garamond', serif;
        font-size: 1.1rem;
        transition: all 0.4s ease;
      }

      /* Hover Interaction */
      .nav-links a:hover {
        color: var(--teal-accent);
        letter-spacing: 1px;
        transform: translateY(-2px);
      }

      section {
        max-width: 1000px;
        margin: 0 auto;
        padding: 4rem 2rem;
      }
    </style>
  </head>
  <body>
    <nav>
      <a href="/" class="logo">SV</a>
      <div class="nav-links">
        <a href="/">Home</a>
        <a href="/resume">Resume</a>
        <a href="/art">Art</a>
        <a href="/prose">Prose</a>
        <a href="/contact">Contact</a>
      </div>
    </nav>
    <slot />
  </body>
</html>