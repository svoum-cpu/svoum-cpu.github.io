---
const { title } = Astro.props;
---
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <title>{title} | Sofia Voumvourakis</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;700;900&family=Playfair+Display:ital,wght@0,700;1,700&display=swap" rel="stylesheet">
  </head>
  <body>
    <nav>
      <div class="nav-container">
        <a href="/" class="logo">S.E.V.</a>
        <div class="nav-links">
          <a href="/">Home</a>
          <a href="/resume">Resume</a>
          <a href="/art">Art</a>
          <a href="/blog">Blog</a>
          <a href="/contact">Contact</a>
        </div>
      </div>
    </nav>
    <slot />
    <style is:global>
      :root {
        --cool-grey: #F3F4F6;
        --ocean-blue: #1E40AF;
        --soft-turquoise: #2DD4BF;
        --dark-navy: #0F172A;
      }
      body { 
        background-color: var(--cool-grey); /* 60% base */
        color: var(--dark-navy); 
        font-family: 'Inter', sans-serif;
        margin: 0;
        line-height: 1.6;
      }
      nav { 
        background: var(--ocean-blue); /* 30% structure */
        padding: 1.5rem 0;
        color: white;
      }
      .nav-container {
        max-width: 1100px;
        margin: 0 auto;
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 0 2rem;
      }
      .logo { font-family: 'Playfair Display', serif; font-weight: 700; font-size: 1.5rem; text-decoration: none; color: var(--soft-turquoise); }
      .nav-links a { color: white; text-decoration: none; margin-left: 2rem; font-weight: 400; transition: color 0.3s; }
      .nav-links a:hover { color: var(--soft-turquoise); }
      h1, h2 { font-family: 'Playfair Display', serif; color: var(--ocean-blue); }
      section { max-width: 900px; margin: 4rem auto; padding: 0 2rem; }
    </style>
  </body>
</html>