<style>
  .art-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 2rem;
    margin-top: 2rem;
  }
  .art-card {
    background: white;
    padding: 1rem;
    border-bottom: 4px solid var(--soft-turquoise); /* 10% accent */
    transition: transform 0.3s ease;
  }
  .art-card:hover { transform: translateY(-10px); }
  .image-placeholder {
    background: #e5e7eb;
    aspect-ratio: 1;
    width: 100%;
  }
</style>