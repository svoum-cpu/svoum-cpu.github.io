---
import Layout from '../layouts/Layout.astro';
import { Image } from 'astro:assets';
import threeAliens from '../assets/sketch1.jpg'; //Imports sketch1
import orangeAbstract from '../assets/sketch12.jpg'; //Imports sketch12
import greenAbstract from '../assets/sketch11.png'; //Imports sketch11
import blueAbstract from '../assets/sketch6.png'; //Imports sketch6
import threeFaces from '../assets/sketch19.png'; //Imports sketch19
import blackAbstract from '../assets/sketch17.png'; //Imports sketch17
import multiAbstract1 from '../assets/sketch4.png'; //Imports sketch4
import multiAbstract2 from '../assets/sketch5.png'; //Imports sketch5
import orangeFace from '../assets/sketch15.png'; //Imports sketch15
import blueFish from '../assets/sketch9.png'; //Imports sketch9
import gildedAge from '../assets/sketch20.jpg'; //Imports sketch20
import trioAbstract from '../assets/sketch7.jpg'; //Imports sketch7
import multiGiraffe from '../assets/sketch8.png'; //Imports sketch8
import twoFlowers from '../assets/sketch10.png'; //Imports sketch10
import lineFace from '../assets/sketch14.jpg'; //Imports sketch14
import chaosSketch from '../assets/sketch3.jpg'; //Imports sketch3
import threeHeads from '../assets/sketch16.png'; //Imports sketch16
import brokenFace from '../assets/sketch18.png'; //Imports sketch18
import oldSketch from '../assets/sketch13.jpg'; //Imports sketch13
import aussieSketch from '../assets/sketch2.jpg'; //Imports sketch2
import tigerSketch from '../assets/sketch21.png'; //Imports sketch21
import pinkFace from '../assets/sketch22.png'; //Imports sketch22
import abstractFace from '../assets/sketch23.png'; //Imports sketch 23
---

<Layout title="Art">
  <div class="art-grid-container">
    <div class="art-grid">
      <div class="art-item"><Image src={threeAliens} alt="Artwork" /></div>
      <div class="art-item"><Image src={orangeAbstract} alt="Artwork" /></div>
      <div class="art-item"><Image src={greenAbstract} alt="Artwork" /></div>
      <div class="art-item"><Image src={blueAbstract} alt="Artwork" /></div>
      <div class="art-item"><Image src={threeFaces} alt="Artwork" /></div>
      <div class="art-item"><Image src={blackAbstract} alt="Artwork" /></div>
      <div class="art-item"><Image src={multiAbstract1} alt="Artwork" /></div>
      <div class="art-item"><Image src={multiAbstract2} alt="Artwork" /></div>
      <div class="art-item"><Image src={orangeFace} alt="Artwork" /></div>
      <div class="art-item"><Image src={blueFish} alt="Artwork" /></div>
      <div class="art-item"><Image src={gildedAge} alt="Artwork" /></div>
      <div class="art-item"><Image src={trioAbstract} alt="Artwork" /></div>
      <div class="art-item"><Image src={multiGiraffe} alt="Artwork" /></div>
      <div class="art-item"><Image src={twoFlowers} alt="Artwork" /></div>
      <div class="art-item"><Image src={lineFace} alt="Artwork" /></div>
      <div class="art-item"><Image src={chaosSketch} alt="Artwork" /></div>
      <div class="art-item"><Image src={threeHeads} alt="Artwork" /></div>
      <div class="art-item"><Image src={brokenFace} alt="Artwork" /></div>
      <div class="art-item"><Image src={oldSketch} alt="Artwork" /></div>
      <div class="art-item"><Image src={aussieSketch} alt="Artwork" /></div>
      <div class="art-item"><Image src={tigerSketch} alt="Artwork" /></div>
      <div class="art-item"><Image src={pinkFace} alt="Artwork" /></div>
      <div class="art-item"><Image src={abstractFace} alt="Artwork" /></div>
    </div>
  </div>
</Layout>

<style>
  .art-grid-container {
    padding: 2rem 5%;
  }
  .art-grid {
    display: grid;
    /* Fixed 3-column grid that doesn't overlap */
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: 1.5rem;
  }
  .art-item {
    background: white;
    padding: 10px;
    border: 1px solid #ddd;
    transition: transform 0.3s ease;
  }
  .art-item:hover {
    transform: translateY(-5px);
    border-color: var(--muted-teal);
  }
  .art-item img {
    width: 100%;
    height: auto;
    aspect-ratio: 4 / 5; /* Forces all images to a consistent shape */
    object-fit: cover;
  }
</style>