---
import Layout from '../layouts/Layout.astro';
import { Image } from 'astro:assets';
import threeAliens from '../assets/sketch1.jpg'; //Imports sketch1
import chaosSketch from '../assets/sketch3.jpg'; //Imports sketch3
import trioAbstract from '../assets/sketch7.jpg'; //Imports sketch7

import brokenFace from '../assets/sketch18.png'; //Imports sketch18
import orangeAbstract from '../assets/sketch12.jpg'; //Imports sketch12
import threeHeads from '../assets/sketch16.png'; //Imports sketch16

import greenAbstract from '../assets/sketch11.png'; //Imports sketch11
import blueAbstract from '../assets/sketch6.png'; //Imports sketch6
import blackAbstract from '../assets/sketch17.png'; //Imports sketch17
---
<Layout title="Art">
  <div class="gallery-wrapper">
    <div class="editorial-grid">
      <div class="grid-item">
        <a href="#expand1"><Image src={threeAliens} alt="Artwork" class="gallery-img"/></a>
      </div>
      <div class="grid-item">
        <a href="#expand2"><Image src={chaosSketch} alt="Artwork" class="gallery-img"/></a>
      </div>
      <div class="grid-item">
        <a href="#expand3"><Image src={trioAbstract} alt="Artwork" class="gallery-img"/></a>
      </div>
      <div class="grid-item">
        <a href="#expand4"><Image src={brokenFace} alt="Artwork" class="gallery-img"/></a>
      </div>
      <div class="grid-item">
        <a href="#expand5"><Image src={orangeAbstract} alt="Artwork" class="gallery-img"/></a>
      </div>
      <div class="grid-item">
        <a href="#expand6"><Image src={threeHeads} alt="Artwork" class="gallery-img"/></a>
      </div>
      <div class="grid-item">
        <a href="#expand7"><Image src={greenAbstract} alt="Artwork" class="gallery-img"/></a>
      </div>
      <div class="grid-item">
        <a href="#expand8"><Image src={blueAbstract} alt="Artwork" class="gallery-img"/></a>
      </div>
      <div class="grid-item">
        <a href="#expand9"><Image src={blackAbstract} alt="Artwork" class="gallery-img"/></a>
    </div>

    <div id="expand1" class="modal"><a href="#" class="modal-close"></a><div class="modal-content"><Image src={threeAliens} alt="Artwork" /></div></div>
    <div id="expand2" class="modal"><a href="#" class="modal-close"></a><div class="modal-content"><Image src={chaosSketch} alt="Artwork" /></div></div>
    <div id="expand3" class="modal"><a href="#" class="modal-close"></a><div class="modal-content"><Image src={trioAbstract} alt="Artwork" /></div></div>
    <div id="expand4" class="modal"><a href="#" class="modal-close"></a><div class="modal-content"><Image src={brokenFace} alt="Artwork" /></div></div>
    <div id="expand5" class="modal"><a href="#" class="modal-close"></a><div class="modal-content"><Image src={orangeAbstract} alt="Artwork" /></div></div>
    <div id="expand6" class="modal"><a href="#" class="modal-close"></a><div class="modal-content"><Image src={threeHeads} alt="Artwork" /></div></div>
    <div id="expand7" class="modal"><a href="#" class="modal-close"></a><div class="modal-content"><Image src={greenAbstract} alt="Artwork" /></div></div>
    <div id="expand8" class="modal"><a href="#" class="modal-close"></a><div class="modal-content"><Image src={blueAbstract} alt="Artwork" /></div></div>
    <div id="expand9" class="modal"><a href="#" class="modal-close"></a><div class="modal-content"><Image src={blackAbstract} alt="Artwork" /></div></div>
  </div>
</Layout>

<style>
  .gallery-wrapper { padding: 4rem 5%; }
  .editorial-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
    gap: 30px;
  }
  .gallery-img {
    width: 100%;
    height: 450px;
    object-fit: cover;
    display: block;
    /* Teal Border Added */
    border: 4px solid var(--accent-teal);
    transition: transform 0.3s ease;
  }
  .gallery-img:hover { transform: scale(1.02); }

  /* Super Dark Teal Modal Background */
  .modal {
    display: none;
    position: fixed;
    top: 0; left: 0;
    width: 100%; height: 100%;
    background: rgba(10, 26, 25, 0.98); 
    z-index: 1000;
    justify-content: center;
    align-items: center;
  }
  .modal:target { display: flex; }
  .modal-content img { max-width: 90%; max-height: 85vh; border: 2px solid var(--accent-teal); }
  .modal-close { position: absolute; width: 100%; height: 100%; cursor: zoom-out; }
</style>