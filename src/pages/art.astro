---
import Layout from '../layouts/Layout.astro';
import { Image } from 'astro:assets';
import threeAliens from '../assets/sketch1.jpg'; //Imports sketch1
import chaosSketch from '../assets/sketch3.jpg'; //Imports sketch3
import trioAbstract from '../assets/sketch7.jpg'; //Imports sketch7

import brokenFace from '../assets/sketch18.png'; //Imports sketch18
import orangeAbstract from '../assets/sketch12.jpg'; //Imports sketch12
import threeHeads from '../assets/sketch16.png'; //Imports sketch16

import greenAbstract from '../assets/sketch11.png'; //Imports sketch11
import blueAbstract from '../assets/sketch6.png'; //Imports sketch6
import blackAbstract from '../assets/sketch17.png'; //Imports sketch17
---

<Layout title="Art">
  <div class="art-page">
    <div class="art-grid">
      <a href="#threeAliens" class="art-item"><Image src={threeAliens} alt="Art 1" /></a>
      <a href="#chaosSketch" class="art-item"><Image src={chaosSketch} alt="Art 2" /></a>
      <a href="#trioAbstract" class="art-item"><Image src={trioAbstract} alt="Art 3" /></a>
      <a href="#brokenFace" class="art-item"><Image src={brokenFace} alt="Art 4" /></a>
      <a href="#orangeAbstract" class="art-item"><Image src={orangeAbstract} alt="Art 5" /></a>
      <a href="#threeHeads" class="art-item"><Image src={threeHeads} alt="Art 6" /></a>
      <a href="#greenAbstract" class="art-item"><Image src={greenAbstract} alt="Art 7" /></a>
      <a href="#blueAbstract" class="art-item"><Image src={blueAbstract} alt="Art 8" /></a>
      <a href="#blackAbstract" class="art-item"><Image src={blackAbstract} alt="Art 9" /></a>
    </div>

      <div id ="threeAliens" class="lightbox"><a href="#" class="close"></a><Image src={threeAliens} alt="Art 1" /></div>
      <div id ="chaosSketch" class="lightbox"><a href="#" class="close"></a><Image src={chaosSketch} alt="Art 2" /></div>
      <div id ="trioAbstract" class="lightbox"><a href="#" class="close"></a><Image src={trioAbstract} alt="Art 3" /></div>
      <div id ="brokenFace" class="lightbox"><a href="#" class="close"></a><Image src={brokenFace} alt="Art 4" /></div>
      <div id ="orangeAbstract" class="lightbox"><a href="#" class="close"></a><Image src={orangeAbstract} alt="Art 5" /></div>
      <div id ="threeHeads" class="lightbox"><a href="#" class="close"></a><Image src={threeHeads} alt="Art 6" /></div>
      <div id ="greenAbstract" class="lightbox"><a href="#" class="close"></a><Image src={greenAbstract} alt="Art 7" /></div>
      <div id ="blueAbstract" class="lightbox"><a href="#" class="close"></a><Image src={blueAbstract} alt="Art 8" /></div>
      <div id ="blackAbstract" class="lightbox"><a href="#" class="close"></a><Image src={blackAbstract} alt="Art 9" /></div>
    </div>
</Layout>

<style>
  .art-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 30px;
    padding: 2rem;
  }
  .art-item img {
    width: 100%;
    height: 350px;
    object-fit: cover;
    border-radius: 5px;
    transition: transform 0.3s;
  }
  .art-item:hover img { transform: scale(1.03); }

  /* Lightbox Logic */
  .lightbox {
    display: none;
    position: fixed;
    z-index: 999;
    top: 0; left: 0;
    width: 100%; height: 100%;
    background: rgba(0,0,0,0.8);
    justify-content: center;
    align-items: center;
  }
  .lightbox:target { display: flex; }
  .lightbox img { max-width: 90%; max-height: 80%; border: 5px solid white; }
  .close { position: absolute; width: 100%; height: 100%; cursor: default; }
</style>