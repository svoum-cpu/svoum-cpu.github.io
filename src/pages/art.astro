---
import Layout from '../layouts/Layout.astro';
import { Image } from 'astro:assets';
import threeAliens from '../assets/sketch1.jpg'; //Imports sketch1
import chaosSketch from '../assets/sketch3.jpg'; //Imports sketch3
import trioAbstract from '../assets/sketch7.jpg'; //Imports sketch7

import brokenFace from '../assets/sketch18.png'; //Imports sketch18
import orangeAbstract from '../assets/sketch12.jpg'; //Imports sketch12
import threeHeads from '../assets/sketch16.png'; //Imports sketch16

import greenAbstract from '../assets/sketch11.png'; //Imports sketch11
import blueAbstract from '../assets/sketch6.png'; //Imports sketch6
import blackAbstract from '../assets/sketch17.png'; //Imports sketch17
---

<Layout title="Art">
  <div class="art-grid-container">
    <div class="art-grid">
      <div class="art-item"><Image src={threeAliens} alt="Artwork" /></div>
      <div class="art-item"><Image src={chaosSketch} alt="Artwork" /></div>
      <div class="art-item"><Image src={trioAbstract} alt="Artwork" /></div>
      <div class="art-item"><Image src={brokenFace} alt="Artwork" /></div>
      <div class="art-item"><Image src={orangeAbstract} alt="Artwork" /></div>
      <div class="art-item"><Image src={threeHeads} alt="Artwork" /></div>
      <div class="art-item"><Image src={greenAbstract} alt="Artwork" /></div>
      <div class="art-item"><Image src={blueAbstract} alt="Artwork" /></div>
      <div class="art-item"><Image src={blackAbstract} alt="Artwork" /></div>
  
    </div>
  </div>
</Layout>

<style>
  .art-grid-container {
    padding: 2rem 5%;
  }
  .art-grid {
    display: grid;
    /* Fixed 3-column grid that doesn't overlap */
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: 1.5rem;
  }
  .art-item {
    background: white;
    padding: 10px;
    border: 1px solid #ddd;
    transition: transform 0.3s ease;
  }
  .art-item:hover {
    transform: translateY(-5px);
    border-color: var(--muted-teal);
  }
  .art-item img {
    width: 100%;
    height: auto;
    aspect-ratio: 4 / 5; /* Forces all images to a consistent shape */
    object-fit: cover;
  }
</style>