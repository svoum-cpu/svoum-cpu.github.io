---
import Layout from '../layouts/Layout.astro';
---
<Layout title="Resume">
  <div class="resume-wrapper">
    <aside class="resume-sidebar">
      <button class="tab-link active" onclick="openTab(event, 'education')">Education</button>
      <button class="tab-link" onclick="openTab(event, 'research')">Research</button>
      <button class="tab-link" onclick="openTab(event, 'projects')">Projects</button>
      <button class="tab-link" onclick="openTab(event, 'experience')">Experience</button>
      <button class="tab-link" onclick="openTab(event, 'skills')">Skills</button>
    </aside>

    <main class="resume-content-area">
      <div id="education" class="tab-content active">
        <h2 class="dark-teal-header">Education</h2>
        <div class="box">
          <p><strong>William & Mary</strong>, Williamsburg, VA</p>
          <p><strong>Bachelor of Arts, Intended Majors: Government, Data Science (Dean's List)</strong> | Exp. May 2028</p>
          <ul class="resume-list">
            <li><strong>Relevant Coursework:</strong> Problem Solving with Generative AI, Introduction to Data Science, Research Methods, Philosophy of Technology, International Security, Introduction to Political Theory</li>
          </ul>
        </div>
        <div class="box">
          <p><strong>Brooklyn Technical High School</strong>, Brooklyn, NY</p>
          <p><strong>Advanced Regents Diploma | Law & Society Major</strong> | June 2024</p>
        </div>
      </div>

      <div id="research" class="tab-content">
        <h2 class="dark-teal-header">Research Experience</h2>
        <div class="box">
          <p><strong>Democratic Erosion Project</strong>, Williamsburg, VA</p>
          <p><strong>Project Manager</strong> | Aug 2025 – Present</p>
          <ul class="resume-list">
            <li>Spearheaded onboarding and technical training of 14 research assistants on subnational democratic erosion identification and data entry protocols.</li>
            <li>Optimized training by producing a 20-minute instructional video to clarify and supplement existing training materials for future research cohorts.</li>
            <li>Identified and synthesized relevant news articles from 2008-2024 about threats to democratic institutions in the United States.</li>
          </ul>
        </div>
      </div>

      <div id="projects" class="tab-content">
        <h2 class="dark-teal-header">Research Projects</h2>
        <div class="box">
          <p><strong>Facial Recognition Technology (FRT)</strong></p>
          <p>Investigated the use of FRT to enhance school security, analyzing technical feasibility and potential implementation challenges.</p>
        </div>
        <div class="box">
          <p><strong>Deepfakes & Female Politicians</strong></p>
          <p>Conducted research on the impact of NCII (Non-Consensual Intimate Imagery) deepfakes on female political participation and digital safety.</p>
        </div>
        <div class="box">
          <p><strong>National School Lunch Program (NSLP)</strong></p>
          <p>Synthesized data regarding the effectiveness and policy reach of the NSLP in varied demographics.</p>
        </div>
      </div>

      <div id="experience" class="tab-content">
        <h2 class="dark-teal-header">Additional Experience</h2>
        <div class="box">
          <p><strong>Office of the Nassau County Executive</strong></p>
          <p><strong>Summer Intern, Office of Crime Victim Advocate (OCVA)</strong> | Jun 2025 – Aug 2025</p>
          <ul class="resume-list">
            <li>Supported community outreach by communicating with families in court and researching victim support groups.</li>
          </ul>
        </div>
        <div class="box">
          <p><strong>Smok-Haus Enterprises</strong></p>
          <p><strong>Marketing & Customer Engagement</strong> | 2019 – 2024</p>
          <ul class="resume-list">
            <li>Designed marketing material and packaging for Tipsy Bull using Procreate and Vectornator.</li>
            <li>Managed and responded to approximately 200 customer reviews to improve brand reputation.</li>
          </ul>
        </div>
      </div>

      <div id="skills" class="tab-content">
        <h2 class="dark-teal-header">Skills</h2>
        <div class="box">
          <p><strong>Technical:</strong> Java, Python, Generative AI Implementation, Data Synthesis</p>
          <p><strong>Professional:</strong> Problem-Solving, Cross-functional Communication, Critical Thinking</p>
          <p><strong>Languages:</strong> Greek (Intermediate), Italian (Intermediate)</p>
        </div>
      </div>
    </main>
  </div>

  <script is:inline>
    function openTab(evt, tabName) {
      var i, tabcontent, tablinks;
      tabcontent = document.getElementsByClassName("tab-content");
      for (i = 0; i < tabcontent.length; i++) { tabcontent[i].style.display = "none"; }
      tablinks = document.getElementsByClassName("tab-link");
      for (i = 0; i < tablinks.length; i++) { tablinks[i].className = tablinks[i].className.replace(" active", ""); }
      document.getElementById(tabName).style.display = "block";
      evt.currentTarget.className += " active";
    }
  </script>
</Layout>

<style>
  .resume-wrapper { display: grid; grid-template-columns: 280px 1fr; min-height: 80vh; }
  .resume-sidebar { padding: 4rem 2rem 4rem 60px; border-right: 1px solid var(--border-line); background: white; }
  
  /* Light Teal Background for content area */
  .resume-content-area { background-color: #e0f2f1; padding: 4rem 10% 4rem 5%; }

  .tab-link {
    display: block; width: 100%; text-align: left; background: none; border: none;
    font-family: 'Cormorant Garamond', serif; font-size: 1.4rem; padding: 1.2rem; cursor: pointer; color: var(--charcoal);
  }
  .tab-link.active { color: var(--accent-teal); font-weight: 600; border-left: 4px solid var(--accent-teal); }

  .tab-content { display: none; }
  .tab-content.active { display: block; }
  
  .dark-teal-header { color: var(--dark-teal); font-size: 2.8rem; margin-bottom: 2rem; border-bottom: 1.5px solid var(--accent-teal); padding-bottom: 0.5rem; }
  
  /* White boxes resting on the teal background */
  .box { background-color: #ffffff; padding: 2.5rem; margin-bottom: 2rem; border-radius: 4px; box-shadow: 0 4px 15px rgba(0,0,0,0.05); }
  .resume-list { padding-left: 1.2rem; margin-top: 1rem; }
  .resume-list li { margin-bottom: 0.8rem; }
</style>