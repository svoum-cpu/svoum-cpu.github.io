---
import Layout from '../layouts/Layout.astro';
---
<Layout title="Resume">
  <div class="resume-grid">
    <aside class="resume-menu">
      <button class="nav-btn active" onclick="showSection('education')">Education</button>
      <button class="nav-btn" onclick="showSection('research')">Research</button>
      <button class="nav-btn" onclick="showSection('work')">Policy & Projects</button>
      <button class="nav-btn" onclick="showSection('experience')">Experience</button>
      <button class="nav-btn" onclick="showSection('skills')">Skills</button>
    </aside>

    <main class="resume-view">
      <section id="education" class="resume-box active">
        <h2 class="dark-teal-head">Education</h2>
        <div class="entry">
          <p><strong>William & Mary</strong>, Williamsburg, VA</p>
          <p class="sub"><strong>Bachelor of Arts, Intended Majors: Government, Data Science (Dean's List)</strong> | Exp. May 2028</p>
          <ul class="list">
            <li><strong>Technology & Data:</strong> Problem Solving with Generative AI, Introduction to Data Science</li>
            <li><strong>Research & Policy:</strong> Research Methods, Philosophy of Technology, International Security, Political Theory</li>
          </ul>
        </div>
        <div class="entry">
          <p><strong>Brooklyn Technical High School</strong>, Brooklyn, NY</p>
          <p class="sub"><strong>Advanced Regents Diploma | Law & Society Major</strong> | June 2024</p>
        </div>
      </section>

      <section id="research" class="resume-box">
        <h2 class="dark-teal-head">Research Experience</h2>
        <div class="entry">
          <p><strong>Democratic Erosion Project</strong>, Williamsburg, VA</p>
          <p class="sub"><strong>Project Manager</strong> | Aug 2025 – Present</p>
          <ul class="list">
            <li>Spearheaded onboarding and technical training for 14 research assistants.</li>
            <li>Produced a 20-minute instructional video for future research cohorts.</li>
          </ul>
        </div>
      </section>

      <section id="work" class="resume-box">
        <h2 class="dark-teal-head">Policy Work & Projects</h2>
        <div class="entry">
          <p><strong>Facial Recognition Technology (FRT)</strong></p>
          <p><strong>Lead Researcher</strong></p>
          <p>Analyzed technical feasibility and implementation challenges of FRT in school security.</p>
        </div>
        <div class="entry">
          <p><strong>Deepfakes & Politics</strong></p>
          <p>Researched the impact of NCII deepfakes on female political participation.</p>
        </div>
      </section>

      <section id="experience" class="resume-box">
        <h2 class="dark-teal-head">Additional Experience</h2>
        <div class="entry">
          <p><strong>Office of the Nassau County Executive</strong></p>
          <p class="sub"><strong>Summer Intern, Crime Victim Advocate (OCVA)</strong> | 2025</p>
        </div>
        <div class="entry">
          <p><strong>Smok-Haus Enterprises</strong></p>
          <p class="sub"><strong>Marketing & Customer Engagement</strong> | 2019 – 2024</p>
        </div>
      </section>

      <section id="skills" class="resume-box">
        <h2 class="dark-teal-head">Technical & Linguistic Skills</h2>
        <p><strong>Java, Python, Problem-Solving, Communication, Critical Thinking</strong></p>
        <p><strong>Greek (Intermediate), Italian (Intermediate)</strong></p>
      </section>
    </main>
  </div>

  <script is:inline>
    function showSection(id) {
      // Hide all boxes
      document.querySelectorAll('.resume-box').forEach(box => box.classList.remove('active'));
      // Deactivate all buttons
      document.querySelectorAll('.nav-btn').forEach(btn => btn.classList.remove('active'));
      // Show selected
      document.getElementById(id).classList.add('active');
      event.currentTarget.classList.add('active');
    }
  </script>
</Layout>

<style>
  .resume-grid { display: grid; grid-template-columns: 250px 1fr; gap: 3rem; padding: 4rem 5%; }
  
  .resume-menu {
    border-right: 1px solid var(--border-color);
    padding-right: 2rem;
    /* Pushed to the right from the browser edge */
    margin-left: 20px; 
  }

  .nav-btn {
    display: block;
    width: 100%;
    text-align: left;
    background: none;
    border: none;
    font-family: 'Cormorant Garamond', serif;
    font-size: 1.3rem;
    padding: 1rem;
    cursor: pointer;
    color: var(--charcoal);
    transition: 0.3s;
    border-radius: 5px;
  }

  .nav-btn.active {
    background: var(--margin-color);
    color: var(--bright-teal);
    font-weight: bold;
  }

  .resume-view { min-height: 500px; }

  /* Boxed section styling */
  .resume-box {
    display: none;
    padding: 2.5rem;
    border: 2px solid var(--margin-color);
    animation: fadeIn 0.4s ease;
  }

  .resume-box.active { display: block; }

  .dark-teal-head {
    color: var(--deep-teal);
    font-size: 2.5rem;
    margin-top: 0;
    border-bottom: 1px solid var(--margin-color);
    padding-bottom: 1rem;
  }

  .entry { margin-bottom: 2rem; }
  .list { padding-left: 1.2rem; }

  @keyframes fadeIn { from { opacity: 0; transform: translateY(10px); } to { opacity: 1; transform: translateY(0); } }
</style>