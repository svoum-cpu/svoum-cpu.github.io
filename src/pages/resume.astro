---
import Layout from '../layouts/Layout.astro';
---
<Layout title="Resume">
  <div class="resume-container">
    <aside class="resume-sidebar">
      <h3 class="elegant-title">Navigation</h3>
      <a href="#education">Education</a>
      <a href="#skills">Skills</a>
      <a href="#research">Research</a>
      <a href="#projects">Policy Work</a>
      <a href="#experience">Experience</a>
    </aside>

    <main class="resume-body">
      <section id="education">
        <h2 class="creative-header section-head">Education</h2>
        <div class="entry">
          <h3 class="elegant-title">William & Mary</h3>
          <p class="details">B.A. Intended Majors: Government, Data Science (Dean's List) | Exp. May 2028</p>
          <ul class="resume-list">
            <li><strong>Technology & Data:</strong> Problem Solving with Generative AI, Intro to Data Science.</li>
            <li><strong>Research & Policy:</strong> Research Methods, Philosophy of Technology, International Security, Political Theory.</li>
          </ul>
        </div>
        <div class="entry">
          <h3 class="elegant-title">Brooklyn Technical High School</h3>
          <p class="details">Advanced Regents Diploma | Law & Society Major | June 2024</p>
        </div>
      </section>

      <section id="skills">
        <h2 class="creative-header section-head">Skills</h2>
        <p>Java | Python | Generative AI Implementation | Problem-Solving | Communication | Critical Thinking</p>
        <p><strong>Languages:</strong> Greek (Intermediate), Italian (Intermediate)</p>
      </section>

      <section id="research">
        <h2 class="creative-header section-head">Research Experience</h2>
        <div class="entry">
          <h3 class="elegant-title">Democratic Erosion Project</h3>
          <p class="role">Project Manager (Aug 2025-Present)</p>
          <ul class="resume-list">
            <li>Spearheaded onboarding for 14 research assistants on democratic erosion data entry.</li>
            <li>Produced a 20-minute instructional video for future research cohorts.</li>
            <li>Synthesized news articles (2008-2024) regarding threats to democratic institutions.</li>
          </ul>
        </div>
      </section>

      <section id="projects">
        <h2 class="creative-header section-head">Research Projects</h2>
        <div class="entry">
          <h3 class="elegant-title">Digital Rights & Security</h3>
          <ul class="resume-list">
            <li><strong>Deepfakes:</strong> Impact of NCII deepfakes on female politicians.</li>
            <li><strong>FRT:</strong> Technical feasibility of Facial Recognition in schools.</li>
            <li><strong>Policy:</strong> National School Lunch Program (NSLP) effectiveness.</li>
          </ul>
        </div>
      </section>

      <section id="experience">
        <h2 class="creative-header section-head">Additional Experience</h2>
        <div class="entry">
          <h3 class="elegant-title">Nassau County Executive</h3>
          <p class="role">OCVA Intern (Jun 2025-Aug 2025)</p>
          <p>Supported community outreach and client services in court settings.</p>
        </div>
        <div class="entry">
          <h3 class="elegant-title">Smok-Haus Enterprises</h3>
          <p class="role">Marketing & Customer Engagement (2019-2024)</p>
          <p>Designed packaging for "Tipsy Bull" using Procreate/Vectornator; managed ~200 reviews.</p>
        </div>
      </section>
    </main>
  </div>
</Layout>

<style>
  .resume-container { display: flex; gap: 4rem; }
  .resume-sidebar {
    position: sticky;
    top: 2rem;
    height: fit-content;
    background: var(--tan-sidebar);
    padding: 2rem;
    min-width: 180px;
    border-radius: 15px;
  }
  .resume-sidebar a {
    display: block;
    padding: 0.8rem 0;
    text-decoration: none;
    color: var(--charcoal);
    font-weight: bold;
    border-bottom: 1px solid var(--soft-teal);
  }
  .resume-sidebar a:hover { color: var(--teal-accent); }
  
  .section-head { font-size: 3.5rem; color: var(--teal-accent); margin-bottom: 1rem; }
  .entry { margin-bottom: 3rem; }
  .details { font-style: italic; color: var(--teal-accent); }
  .resume-list { padding-left: 1.2rem; }
</style>