---
import Layout from '../layouts/Layout.astro';
---
<Layout title="Resume">
  <div class="resume-layout">
    <aside class="sidebar-nav">
      <a href="#education">Education</a>
      <a href="#research">Research</a>
      <a href="#projects">Projects</a>
      <a href="#experience">Experience</a>
      <a href="#skills">Skills</a>
    </aside>

    <div class="content">
      <section id="education">
        <h2>Education</h2>
        <div class="entry">
          <h3>William & Mary <span class="date">Exp. May 2028</span></h3>
          <p class="sub">B.A. Government & Data Science (Dean's List)</p>
        </div>
        <div class="entry">
          <h3>Brooklyn Technical High School <span class="date">June 2024</span></h3>
          <p class="sub">Advanced Regents Diploma | Law & Society Major</p>
        </div>
      </section>

      <section id="research">
        <h2>Research Experience</h2>
        <div class="entry">
          <h3>Democratic Erosion Project <span class="date">Aug 2025 – Present</span></h3>
          <p class="role">Project Manager</p>
          <ul>
            <li>Spearheaded onboarding and technical training for 14 research assistants on subnational democratic erosion.</li>
            <li>Optimized training by producing a 20-minute instructional video for future research cohorts.</li>
          </ul>
        </div>
      </section>

      <section id="projects">
        <h2>Research Projects</h2>
        <div class="entry">
          <h3>Deepfakes & Political Participation</h3>
          <p>Analyzed the impact of NCII deepfakes on female politicians, focusing on digital rights and democratic integrity.</p>
        </div>
        <div class="entry">
          <h3>Facial Recognition Technology (FRT)</h3>
          <p>Investigated the use of FRT in school security, analyzing technical feasibility and civil liberty implications.</p>
        </div>
      </section>

      <section id="experience">
        <h2>Additional Experience</h2>
        <div class="entry">
          <h3>Office of the Nassau County Executive <span class="date">Summer 2025</span></h3>
          <p class="role">Crime Victim Advocate Intern</p>
        </div>
        <div class="entry">
          <h3>Smok-Haus Enterprises <span class="date">2019 – 2024</span></h3>
          <p class="role">Marketing & Design</p>
        </div>
      </section>

      <section id="skills">
        <h2>Skills</h2>
        <p><strong>Technical:</strong> Java, Python, Problem-Solving, Data Entry</p>
        <p><strong>Languages:</strong> Greek (Intermediate), Italian (Intermediate)</p>
      </section>
    </div>
  </div>
</Layout>

<style>
  .resume-layout {
    display: grid;
    grid-template-columns: 200px 1fr;
    gap: 4rem;
    margin-top: 2rem;
  }
  .sidebar-nav {
    position: sticky;
    top: 4rem;
    height: fit-content;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }
  .sidebar-nav a {
    text-decoration: none;
    color: var(--muted-teal);
    font-family: 'Cormorant Garamond', serif;
    font-size: 1.2rem;
    border-left: 2px solid transparent;
    padding-left: 1rem;
    transition: 0.3s;
  }
  .sidebar-nav a:hover {
    border-left: 2px solid var(--muted-teal);
    background: var(--pastel-teal);
  }
  h2 {
    font-size: 2.2rem;
    border-bottom: 1px solid var(--muted-teal);
    margin-bottom: 2rem;
    color: var(--muted-teal);
  }
  .entry { margin-bottom: 2.5rem; }
  .date { float: right; font-size: 1rem; color: var(--text-grey); font-family: "Times New Roman", serif; font-weight: normal; }
  .sub { font-style: italic; margin-bottom: 0.5rem; }
  ul { padding-left: 1.2rem; margin-top: 0.5rem; }
</style>