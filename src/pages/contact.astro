---
import Layout from '../layouts/Layout.astro';
---
<Layout title="Contact">
  <div class="contact-wrap">
    <h1 class="creative-header contact-title"><u>Get in Touch</u></h1>
    <p class="contact-sub">I’d like to hear from you!</p>

    <div class="links">
      <a href="mailto:sev@wm.edu">sev@wm.edu</a> | 
      <a href="tel:5160000000">(516) 000-0000</a>
    </div>

    <form class="contact-form">
      <input type="text" placeholder="Full Name" />
      <input type="email" placeholder="Email Address" />
      <textarea placeholder="Your Message" rows="8"></textarea>
      <button type="submit">Send Message</button>
    </form>
  </div>
</Layout>

<style>
  .contact-wrap { text-align: center; max-width: 600px; margin: 0 auto; }
  .contact-title { font-size: 5rem; font-weight: bold; margin-bottom: 0; }
  .contact-sub { font-size: 1.4rem; font-style: italic; margin-bottom: 3rem; }
  .links { margin-bottom: 2rem; font-size: 1.2rem; }
  .links a { color: var(--teal-accent); text-decoration: none; font-weight: bold; }

  .contact-form {
    display: flex;
    flex-direction: column;
    align-items: center; /* Centers items */
    gap: 1.5rem;
  }
  input, textarea {
    width: 100%; /* Uniform length */
    padding: 1.2rem;
    border: 1px solid var(--soft-teal);
    background: white;
    font-family: "Times New Roman", serif;
  }
  button {
    width: 100%; /* Uniform length with inputs */
    padding: 1.2rem;
    background: var(--teal-accent);
    color: white;
    border: none;
    font-family: 'Cormorant Garamond', serif;
    font-size: 1.3rem;
    cursor: pointer;
    transition: 0.3s;
  }
  button:hover { background: var(--charcoal); }
</style>