---
import Layout from '../layouts/Layout.astro';
---
<Layout title="Contact">
  <div class="contact-container">
    <div class="contact-header">
      <h1>Get in Touch</h1>
      <p class="teal-subheader">I’d like to hear from you!</p>
    </div>

    <form class="contact-form">
      <div class="form-group">
        <label>Full Name</label>
        <input type="text" placeholder="Your Name" required />
      </div>
      <div class="form-group">
        <label>Email Address</label>
        <input type="email" placeholder="Email Address" required />
      </div>
      <div class="form-group message-box">
        <label>Your Message</label>
        <textarea rows="8" placeholder="How can I help you?" required></textarea>
      </div>
      <button type="submit" class="teal-submit">Send message</button>
    </form>

    <div class="contact-info">
      <a href="mailto:sevoumvourakis@wm.edu">sevoumvourakis@wm.edu</a>
    </div>
  </div>
</Layout>

<style>
  .contact-container { max-width: 600px; margin: 4rem auto; text-align: center; }
  
  h1 { font-size: 3.5rem; margin-bottom: 0.5rem; font-weight: 300; }
  .teal-subheader { color: var(--bright-teal); font-size: 1.5rem; font-style: italic; margin-bottom: 3rem; }

  .contact-form {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
    text-align: left;
  }

  .form-group label { display: block; margin-bottom: 0.5rem; font-weight: bold; }
  
  input, textarea {
    width: 100%;
    padding: 1rem;
    border: 1px solid var(--border-color);
    background: #ffffff;
    font-family: "Times New Roman", serif;
    box-sizing: border-box;
  }

  /* Specific box for message entry */
  .message-box textarea {
    border: 2px solid var(--margin-color);
    background: #fdfdfd;
  }

  .teal-submit {
    background-color: var(--bright-teal);
    color: white;
    border: none;
    padding: 1.2rem;
    font-family: 'Cormorant Garamond', serif;
    font-size: 1.2rem;
    cursor: pointer;
    transition: 0.3s;
    text-transform: uppercase;
    letter-spacing: 1px;
  }

  .teal-submit:hover { background-color: var(--deep-teal); }

  .contact-info { margin-top: 3rem; display: flex; justify-content: center; gap: 2rem; }
  .contact-info a { color: var(--charcoal); text-decoration: none; border-bottom: 1px solid var(--border-color); }
</style>